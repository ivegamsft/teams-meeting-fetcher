# Server
PORT=3000
NODE_ENV=development

# AWS Configuration
AWS_REGION=us-east-1

# DynamoDB Tables
DYNAMODB_SUBSCRIPTIONS_TABLE=graph-subscriptions
DYNAMODB_MEETINGS_TABLE=tmf-meetings
DYNAMODB_TRANSCRIPTS_TABLE=tmf-transcripts
DYNAMODB_CONFIG_TABLE=tmf-config

# S3 Buckets
S3_RAW_TRANSCRIPT_BUCKET=tmf-raw-transcripts
S3_SANITIZED_TRANSCRIPT_BUCKET=tmf-sanitized-transcripts

# SQS
SQS_NOTIFICATION_QUEUE_URL=

# AWS Secrets Manager
GRAPH_SECRET_NAME=tmf/graph-credentials

# Microsoft Graph API
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
ENTRA_GROUP_ID=

# Webhook Configuration
WEBHOOK_AUTH_SECRET=
WEBHOOK_CLIENT_STATE=
WEBHOOK_NOTIFICATION_URL=

# Dashboard Authentication
SESSION_SECRET=change-me-in-production
API_KEY=

# Entra ID (Azure AD) OIDC Authentication
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=

# Sanitization
SANITIZATION_ENABLED=true
SANITIZATION_MODE=simulated
