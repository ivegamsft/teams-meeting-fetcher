# Azure AD Application - Graph API access
GRAPH_TENANT_ID=62837751-4e48-4d06-8bcb-57be1a669b78
GRAPH_CLIENT_ID=1b5a61f5-4c7f-41bf-9308-e4adaea6a7c8
GRAPH_CLIENT_SECRET=<your-app-secret>

# Admin Security Group (ALWAYS use group ID, never individual user)
# This group's members' calendars are monitored for changes
ALLOWED_GROUP_ID=5e7708f8-b0d2-467d-97f9-d9da4818084a

# Graph subscription resource - CRITICAL: GROUP path format required
# ❌ WRONG: /users/user@company.com/events (individual user)
# ✅ CORRECT: /groups/5e7708f8-b0d2-467d-97f9-d9da4818084a
GRAPH_SUBSCRIPTION_RESOURCE=/groups/5e7708f8-b0d2-467d-97f9-d9da4818084a

# Azure Event Hub configuration
EVENT_HUB_NAMESPACE=tmf-ehns-eus-6an5wk.servicebus.windows.net
EVENT_HUB_NAME=tmf-eh-eus-6an5wk
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://tmf-ehns-eus-6an5wk.servicebus.windows.net/;SharedAccessKeyName=tmf-eventhub-access;SharedAccessKey=<key>;EntityPath=tmf-eh-eus-6an5wk

# Rich notifications (for payloads > 1MB, stored in blob storage)
GRAPH_RICH_NOTIFICATIONS=true
GRAPH_BLOB_STORE_ENDPOINT=https://tmfsteus6an5wk.blob.core.windows.net
GRAPH_BLOB_STORE_CONTAINER=microsoft-graph-change-notifications

# Webhook endpoint configuration
WEBHOOK_PORT=7071
NOTIFICATION_URL=https://4ej2x5p7al3tfefz7iiru7kwre0ityts.lambda-url.us-east-1.on.aws/webhook

# Data storage
DATA_DIR=./data
