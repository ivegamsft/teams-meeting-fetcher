# E2E Test Environment Configuration
# Copy this file to .env.test and fill in your values

# AWS Configuration
AWS_PROFILE=tmf-dev
AWS_REGION=us-east-1

# Scenario 1: Teams Bot
MEETING_BOT_LAMBDA=meeting-bot-handler-dev
MEETINGS_TABLE=meeting-bot-sessions-dev
TRANSCRIPT_BUCKET=teams-meeting-transcripts-dev
BOT_MESSAGING_ENDPOINT=https://your-api-gateway.execute-api.us-east-1.amazonaws.com/prod/bot

# Scenario 2: EventHub
EVENTHUB_LAMBDA=tmf-eventhub-processor-dev
CHECKPOINT_TABLE=eventhub-checkpoints
EVENTHUB_NAMESPACE=your-eventhub-namespace
EVENTHUB_NAME=teams-meeting-events

# Scenario 3: Direct Graph API (No Bots)
WEBHOOK_LAMBDA=teams-meeting-webhook-dev
NOTIFICATION_URL=https://your-api-gateway.execute-api.us-east-1.amazonaws.com/prod/webhook
BUCKET_NAME=teams-meeting-webhooks-dev
CLIENT_STATE=teams-meeting-fetcher-webhook
WATCH_USER_ID=user@yourdomain.com

# Microsoft Graph API Credentials
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret

# Bot Framework Credentials (Scenario 1)
BOT_APP_ID=your-bot-app-id
BOT_APP_SECRET=your-bot-app-secret

# Azure Configuration (for EventHub scenario)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
