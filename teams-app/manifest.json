{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "version": "1.0.9",
  "manifestVersion": "1.25",
  "id": "5fb90d80-a7cd-43c0-97e3-eb7577e40169",
  "developer": {
    "name": "Your Organization",
    "websiteUrl": "https://your-domain.com",
    "privacyUrl": "https://your-domain.com/privacy",
    "termsOfUseUrl": "https://your-domain.com/terms"
  },
  "name": {
    "short": "Meeting Fetcher",
    "full": "Teams Meeting Fetcher"
  },
  "description": {
    "short": "Automatically record and transcribe Teams meetings",
    "full": "Teams Meeting Fetcher helps your organization automatically record and transcribe Teams meetings. When meeting organizers enable recording, the system automatically fetches the transcriptions for easy reference, compliance, and archival."
  },
  "icons": {
    "color": "icon-color.png",
    "outline": "icon-outline.png"
  },
  "accentColor": "#004578",
  "permissions": ["identity"],
  "validDomains": ["epo20g6lg3.execute-api.us-east-1.amazonaws.com"],
  "defaultInstallScope": "meetings",
  "defaultGroupCapability": {
    "team": "bot",
    "groupchat": "bot",
    "meetings": "tab"
  },
  "webApplicationInfo": {
    "id": "5fb90d80-a7cd-43c0-97e3-eb7577e40169"
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "OnlineMeeting.ReadBasic.Chat",
          "type": "Application"
        },
        {
          "name": "OnlineMeetingTranscript.Read.Chat",
          "type": "Application"
        },
        {
          "name": "OnlineMeetingRecording.Read.Chat",
          "type": "Application"
        }
      ]
    }
  },
  "configurableTabs": [
    {
      "configurationUrl": "https://epo20g6lg3.execute-api.us-east-1.amazonaws.com/dev/bot/config",
      "canUpdateConfiguration": false,
      "scopes": ["groupChat"],
      "context": ["meetingSidePanel", "meetingChatTab", "meetingDetailsTab"]
    }
  ],
  "bots": [
    {
      "botId": "5fb90d80-a7cd-43c0-97e3-eb7577e40169",
      "scopes": ["team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["team", "groupChat"],
          "commands": [
            {
              "title": "Hi",
              "description": "Get a greeting from the bot"
            },
            {
              "title": "Help",
              "description": "Learn what this bot does"
            }
          ]
        }
      ]
    }
  ]
}
